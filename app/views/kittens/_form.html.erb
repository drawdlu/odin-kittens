<div class="form">
    <%= simple_form_for kitten do |f| %>
        <%= f.input :name, input_html: {maxlength: 20} %>
        <%= f.input :age, input_html: {min: 1, max: 25 } %>
        <%= f.input :cuteness, input_html: {min: 1, max: 10 } %>
        <%= f.input :softness, input_html: {min: 1, max: 10 } %>
        <%= f.button :submit %>
    <% end %>
</div>
